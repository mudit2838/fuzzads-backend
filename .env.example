# Server Environment Variables Example
# Copy this file to .env and fill in the actual values
# DO NOT COMMIT .env to git - only .env.example should be in git

# === Database ===
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=

# === Authentication Secrets ===
# Generate with: openssl rand -base64 32 or node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
SESSION_SECRET=

# === Environment ===
# development or production
NODE_ENV=development
PORT=5000

# === Frontend URL ===
# For development: http://localhost:5173
# For production: https://your-frontend-url.onrender.com
CLIENT_URL=http://localhost:5173

# === Google OAuth (optional, if using Google login) ===
# Obtained from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback URL - must match registered URL in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# === Razorpay (optional, if using payment) ===
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# === Email/OTP Service (optional) ===
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
